/* ===============================================
   HOME PAGE - SCREENSHOT DESIGN MATCH
   Red, Black & White Theme
   =============================================== */

/* ANIMATIONS */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInLeft {
  from {
    opacity: 0;
    transform: translateX(-30px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes fadeInRight {
  from {
    opacity: 0;
    transform: translateX(30px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

/* HERO SECTION */
.hero-section {
  padding: 4rem 0 3rem;
  background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
  position: relative;
  overflow: hidden;
}

.hero-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 2rem;
}

/* Hero Content - Left Side */
.hero-content {
  z-index: 2;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.75rem 2rem;
  background: rgba(230, 57, 70, 0.1);
  border-radius: 50px;
  margin-bottom: 2rem;
  font-size: 1.1rem;
  font-weight: 700;
  color: #e63946;
  letter-spacing: 1px;
}

.badge-icon {
  font-size: 1.2rem;
}

.hero-title {
  font-size: 4.5rem;
  font-weight: 900;
  line-height: 1.2;
  color: #1a1a1a;
  margin-bottom: 2rem;
  animation: fadeInUp 0.8s ease-out;
}

.title-highlight {
  color: #e63946;
  display: block;
}

.hero-features-list {
  display: flex;
  gap: 2rem;
  margin-bottom: 2.5rem;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 1rem;
  color: #333333;
}

.check-icon {
  width: 24px;
  height: 24px;
  background: linear-gradient(135deg, #e63946, #c1121f);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.85rem;
  font-weight: bold;
}

.hero-buttons {
  display: flex;
  gap: 1.5rem;
  margin-bottom: 2rem;
}

.hero-trust-badges {
  display: flex;
  gap: 2rem;
  align-items: center;
  padding-top: 1.5rem;
  border-top: 2px solid #eee;
  animation: fadeInUp 0.8s ease-out 0.4s both;
}

.trust-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.trust-icon {
  font-size: 1.2rem;
}

.trust-text {
  font-size: 0.95rem;
  font-weight: 600;
  color: #333;
}


.cta-btn {
  padding: 1rem 2.5rem;
  border-radius: 8px;
  font-size: 1rem;
  font-weight: 600;
  border: none;
  cursor: pointer;
  transition: all 0.3s ease;
}

.cta-primary {
  background: linear-gradient(135deg, #e63946, #c1121f);
  color: white;
  box-shadow: 0 8px 20px rgba(230, 57, 70, 0.3);
}

.cta-primary:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 30px rgba(230, 57, 70, 0.4);
}

.cta-secondary {
  background: transparent;
  color: #333333;
  border: 2px solid #e0e0e0;
}

.cta-secondary:hover {
  border-color: #e63946;
  color: #e63946;
  transform: translateY(-3px);
}

/* Hero Image Section - Right Side */
.hero-image-section {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
}

.hero-circle-bg {
  position: absolute;
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, rgba(230, 57, 70, 0.15) 0%, rgba(230, 57, 70, 0.05) 50%, transparent 70%);
  border-radius: 50%;
  z-index: 1;
  animation: pulse-circle 4s ease-in-out infinite;
}

@keyframes pulse-circle {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.hero-student-image {
  position: relative;
  width: 450px;
  height: 500px;
  object-fit: cover;
  border-radius: 50% 50% 0 0;
  z-index: 2;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
}

.stat-badge {
  position: absolute;
  background: white;
  padding: 1.2rem 1.5rem;
  border-radius: 15px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
  display: flex;
  align-items: center;
  gap: 1rem;
  z-index: 3;
  animation: float-badge 3s ease-in-out infinite;
}

@keyframes float-badge {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}

.badge-students {
  top: 20%;
  left: -10%;
}

.badge-courses {
  bottom: 15%;
  right: -10%;
  animation-delay: 1.5s;
}

.stat-icon {
  font-size: 2.5rem;
}

.stat-content {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.stat-number {
  font-size: 1.5rem;
  font-weight: 900;
  color: #e63946;
  line-height: 1;
}

.stat-label {
  font-size: 0.85rem;
  color: #666666;
  line-height: 1;
}

/* QUICK FEATURES SECTION */
.quick-features {
  padding: 3rem 0;
  background: white;
}

.features-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 2rem;
  gap: 2rem;
}

.feature-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
  flex: 1;
}

.feature-icon-circle {
  width: 80px;
  height: 80px;
  background: linear-gradient(135deg, rgba(230, 57, 70, 0.1), rgba(230, 57, 70, 0.05));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2rem;
  transition: all 0.3s ease;
}

.feature-box:hover .feature-icon-circle {
  background: linear-gradient(135deg, #e63946, #c1121f);
  transform: scale(1.1);
}

.feature-text {
  font-size: 0.95rem;
  font-weight: 600;
  color: #333333;
  text-align: center;
}

/* MISSION SECTION */
.mission-section {
  padding: 6rem 0;
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
}

.mission-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: center;
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 2rem;
}

.mission-image-wrapper {
  position: relative;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
}

.mission-image {
  width: 100%;
  height: auto;
  display: block;
}

.mission-play-button {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80px;
  height: 80px;
  background: linear-gradient(135deg, #e63946, #c1121f);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 10px 30px rgba(230, 57, 70, 0.5);
}

.mission-play-button:hover {
  transform: translate(-50%, -50%) scale(1.15);
}

.play-icon {
  color: white;
  font-size: 1.5rem;
  margin-left: 5px;
}

.mission-right {
  padding: 2rem 0;
}

.section-label {
  display: inline-block;
  padding: 0.75rem 2rem;
  background: rgba(230, 57, 70, 0.1);
  color: #e63946;
  font-size: 1.1rem;
  font-weight: 700;
  border-radius: 50px;
  margin-bottom: 1.5rem;
  letter-spacing: 1.5px;
  text-transform: uppercase;
}

.section-title {
  font-size: 3.5rem;
  font-weight: 900;
  line-height: 1.3;
  color: #1a1a1a;
  margin-bottom: 1.5rem;
  animation: fadeInUp 0.8s ease-out;
}

.section-description {
  font-size: 1.05rem;
  line-height: 1.8;
  color: #666666;
  margin-bottom: 2rem;
}

.mission-features {
  list-style: none;
  padding: 0;
  margin: 2rem 0;
}

.mission-features li {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0.75rem 0;
  font-size: 1rem;
  color: #333333;
  line-height: 1.6;
}

.check-mark {
  width: 24px;
  height: 24px;
  background: linear-gradient(135deg, #e63946, #c1121f);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.85rem;
  font-weight: bold;
  flex-shrink: 0;
}

/* POPULAR COURSES SECTION */
.popular-courses-section {
  padding: 6rem 0;
  background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
}

.section-header-center {
  text-align: center;
  margin-bottom: 3rem;
}

.section-header-center .section-label {
  margin-bottom: 1rem;
}

.section-header-center .section-title {
  font-size: 3.8rem;
  margin-bottom: 0;
  animation: fadeInUp 0.8s ease-out 0.2s both;
}

.course-categories {
  display: flex;
  justify-content: center;
  gap: 1rem;
  margin-bottom: 3rem;
  flex-wrap: wrap;
}

.category-btn {
  padding: 0.75rem 2rem;
  background: white;
  color: #333333;
  font-size: 1rem;
  font-weight: 600;
  border: 2px solid #e0e0e0;
  border-radius: 50px;
  cursor: pointer;
  transition: all 0.3s ease;
}

.category-btn:hover {
  border-color: #e63946;
  color: #e63946;
}

.category-btn.active {
  background: linear-gradient(135deg, #e63946, #c1121f);
  color: white;
  border-color: #e63946;
}

.courses-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2rem;
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 2rem;
}

.course-card {
  background: white;
  border-radius: 15px;
  overflow: hidden;
  box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  cursor: pointer;
}

.course-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 15px 40px rgba(0, 0, 0, 0.15);
}

.course-image-container {
  position: relative;
  width: 100%;
  height: 200px;
  overflow: hidden;
}

.course-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.course-card:hover .course-image {
  transform: scale(1.1);
}

.course-badge {
  position: absolute;
  top: 15px;
  right: 15px;
  padding: 0.4rem 1rem;
  border-radius: 50px;
  font-size: 0.75rem;
  font-weight: 700;
  z-index: 2;
}

.badge-red {
  background: linear-gradient(135deg, #e63946, #c1121f);
  color: white;
}

.course-content {
  padding: 1.5rem;
}

.course-rating {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 0.75rem;
}

.stars {
  color: #ffa500;
  font-size: 0.9rem;
}

.rating-number {
  font-size: 0.9rem;
  color: #666666;
  font-weight: 600;
}

.course-title {
  font-size: 1.1rem;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.4;
  margin-bottom: 1rem;
  min-height: 3em;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.course-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 1rem;
  border-top: 1px solid #f0f0f0;
}

.course-author {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.author-avatar {
  width: 35px;
  height: 35px;
  background: linear-gradient(135deg, #e63946, #c1121f);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 0.9rem;
}

.course-author span {
  font-size: 0.9rem;
  color: #666666;
}

.course-price {
  font-size: 1.1rem;
  font-weight: 900;
  color: #e63946;
}

.view-all-section {
  display: flex;
  justify-content: center;
  margin-top: 3rem;
}

/* RESPONSIVE DESIGN */
@media (max-width: 1200px) {
  .courses-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 992px) {
  .hero-layout,
  .mission-layout {
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .hero-image-section {
    order: -1;
  }

  .hero-student-image {
    width: 350px;
    height: 400px;
  }

  .badge-students,
  .badge-courses {
    left: 10%;
    right: auto;
  }

  .badge-courses {
    left: auto;
    right: 10%;
  }

  .courses-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .hero-title {
    font-size: 2.8rem;
  }

  .section-title {
    font-size: 2.2rem;
  }
}

@media (max-width: 768px) {
  .hero-title {
    font-size: 2.2rem;
  }

  .section-title {
    font-size: 1.8rem;
  }

  .features-row {
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .feature-box {
    min-width: 150px;
  }

  .courses-grid {
    grid-template-columns: 1fr;
  }

  .hero-features-list {
    flex-direction: column;
    gap: 1rem;
  }

  .hero-buttons {
    flex-direction: column;
    gap: 1rem;
  }

  .cta-btn {
    width: 100%;
    text-align: center;
  }

  .hero-trust-badges {
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }
}

/* CONTAINER */
.container {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 2rem;
}

/* ===============================================
   ADDITIONAL SECTIONS STYLING
   =============================================== */

/* ABOUT SECTION */
.about-section {
  padding: 8rem 0;
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
}

.about-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6rem;
  align-items: center;
}

.about-content .section-title {
  font-size: 3.8rem;
  margin-bottom: 2rem;
  animation: fadeInLeft 0.8s ease-out;
}

.highlight-text {
  color: #e63946;
  position: relative;
}

.about-description {
  font-size: 1.1rem;
  line-height: 1.8;
  color: #666666;
  margin-bottom: 3rem;
}

.about-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2rem;
}

.stat-item {
  text-align: center;
}

.stat-number {
  font-size: 3rem;
  font-weight: 900;
  color: #e63946;
  margin-bottom: 0.5rem;
  line-height: 1;
}

.stat-label {
  font-size: 0.95rem;
  color: #666666;
  font-weight: 600;
}

.about-video {
  position: relative;
}

.video-wrapper {
  position: relative;
  padding-bottom: 56.25%;
  height: 0;
  overflow: hidden;
  border-radius: 20px;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
}

.video-wrapper iframe {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 20px;
}

/* WHY CHOOSE SECTION - ENHANCED */
.why-choose-section {
  padding: 8rem 0;
  background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
}

.why-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 2.5rem;
  margin-top: 4rem;
}

.why-card {
  background: white;
  padding: 2.5rem;
  border-radius: 20px;
  transition: all 0.3s ease;
  box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
  border: 2px solid transparent;
  position: relative;
  overflow: hidden;
}

.why-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 4px;
  height: 0;
  background: linear-gradient(180deg, #e63946 0%, #c1121f 100%);
  transition: height 0.3s ease;
}

.why-card:hover {
  transform: translateY(-10px);
  box-shadow: 0 20px 60px rgba(230, 57, 70, 0.2);
  border-color: #e63946;
}

.why-card:hover::before {
  height: 100%;
}

.why-icon {
  font-size: 3.5rem;
  margin-bottom: 1.5rem;
  display: inline-block;
}

.why-card h3 {
  font-size: 1.6rem;
  font-weight: 800;
  color: #1a1a1a;
  margin-bottom: 1rem;
}

.why-card p {
  font-size: 1.05rem;
  color: #555;
  line-height: 1.8;
  margin-bottom: 1.5rem;
}

.why-stats {
  padding-top: 1rem;
  border-top: 2px solid #eee;
}

.stat-mini {
  display: inline-block;
  background: rgba(230, 57, 70, 0.1);
  color: #e63946;
  padding: 0.5rem 1rem;
  border-radius: 20px;
  font-size: 0.9rem;
  font-weight: 700;
}

/* SUCCESS METRICS SECTION */
.success-metrics-section {
  padding: 6rem 0;
  background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
  position: relative;
  overflow: hidden;
}

.success-metrics-section::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -10%;
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, rgba(230, 57, 70, 0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.success-metrics-section .section-label,
.success-metrics-section .section-title,
.success-metrics-section .section-description {
  color: white;
}

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2rem;
  margin-top: 4rem;
  position: relative;
  z-index: 2;
}

.metric-card {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(10px);
  padding: 2.5rem;
  border-radius: 20px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  text-align: center;
  transition: all 0.3s ease;
}

.metric-card:hover {
  background: rgba(255, 255, 255, 0.08);
  transform: translateY(-10px);
  border-color: #e63946;
  box-shadow: 0 20px 50px rgba(230, 57, 70, 0.3);
}

.metric-card.highlight-card {
  background: linear-gradient(135deg, #e63946 0%, #c1121f 100%);
  border: none;
}

.metric-icon {
  font-size: 3rem;
  margin-bottom: 1rem;
}

.metric-number {
  font-size: 3.5rem;
  font-weight: 900;
  color: white;
  margin-bottom: 0.5rem;
  line-height: 1;
}

.metric-label {
  font-size: 1.1rem;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.metric-description {
  font-size: 0.95rem;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.6;
}


/* PROGRAMS SECTION */
.programs-section {
  padding: 8rem 0;
  background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
  color: white;
}

.programs-section .section-label {
  background: rgba(230, 57, 70, 0.2);
}

.programs-section .section-title,
.programs-section .section-description {
  color: white;
}

.programs-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 3rem;
  margin-top: 4rem;
}

.program-card {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(10px);
  padding: 3rem;
  border-radius: 20px;
  border: 2px solid rgba(255, 255, 255, 0.1);
  transition: all 0.4s ease;
  position: relative;
  overflow: hidden;
}

.program-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(230, 57, 70, 0.1), transparent);
  transition: left 0.6s;
}

.program-card:hover::before {
  left: 100%;
}

.program-card:hover {
  transform: translateY(-15px);
  border-color: #e63946;
  box-shadow: 0 30px 80px rgba(230, 57, 70, 0.3);
}

.program-card.featured {
  background: linear-gradient(135deg, rgba(230, 57, 70, 0.2), rgba(193, 18, 31, 0.1));
  border-color: #e63946;
  transform: scale(1.05);
}

.program-badge {
  position: absolute;
  top: 20px;
  right: 20px;
  background: linear-gradient(135deg, #e63946, #c1121f);
  color: white;
  padding: 0.5rem 1rem;
  border-radius: 50px;
  font-size: 0.85rem;
  font-weight: 600;
}

.program-badge.special {
  background: linear-gradient(135deg, #ffa500, #ff6347);
  animation: pulse-badge 2s ease-in-out infinite;
}

@keyframes pulse-badge {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.program-icon {
  font-size: 4rem;
  margin-bottom: 1.5rem;
  display: inline-block;
}

.program-card h3 {
  font-size: 1.8rem;
  font-weight: 700;
  margin-bottom: 1rem;
  color: white;
}

.program-card p {
  font-size: 1.05rem;
  color: #cccccc;
  margin-bottom: 2rem;
  line-height: 1.6;
}

.program-features {
  list-style: none;
  padding: 0;
  margin: 2rem 0;
}

.program-features li {
  padding: 0.75rem 0;
  color: #e0e0e0;
  font-size: 1rem;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.program-btn {
  width: 100%;
  padding: 1rem 2rem;
  border: 2px solid rgba(255, 255, 255, 0.3);
  background: transparent;
  color: white;
  font-size: 1rem;
  font-weight: 600;
  border-radius: 50px;
  cursor: pointer;
  transition: all 0.3s ease;
  margin-top: 1rem;
}

.program-btn:hover {
  background: rgba(255, 255, 255, 0.1);
  border-color: white;
}

.program-btn.primary {
  background: linear-gradient(135deg, #e63946, #c1121f);
  border-color: #e63946;
}

.program-btn.primary:hover {
  background: linear-gradient(135deg, #c1121f, #a4161a);
  transform: scale(1.05);
}

/* PARTNERS SECTION */
.partners-section {
  padding: 4rem 0;
  background: white;
}

.partners-title {
  text-align: center;
  font-size: 2.8rem;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 3rem;
  animation: fadeInUp 0.8s ease-out;
}

.partners-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 2rem;
  align-items: center;
}

.partner-item {
  text-align: center;
  padding: 1.5rem;
  transition: all 0.3s ease;
}

.partner-item:hover {
  transform: scale(1.1);
}

.partner-logo {
  font-size: 1.5rem;
  font-weight: 700;
  color: #666666;
  transition: color 0.3s ease;
}

.partner-item:hover .partner-logo {
  color: #e63946;
}

/* TESTIMONIALS SECTION */
.testimonials-section {
  padding: 8rem 0;
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
}

.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2.5rem;
  margin-top: 4rem;
}

.testimonial-card {
  background: white;
  padding: 2.5rem;
  border-radius: 20px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  border: 2px solid transparent;
}

.testimonial-card:hover {
  transform: translateY(-10px);
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
  border-color: #e63946;
}

.testimonial-card.featured {
  background: linear-gradient(135deg, rgba(230, 57, 70, 0.05), rgba(255, 255, 255, 1));
  border-color: #e63946;
}

.testimonial-stars {
  font-size: 1.5rem;
  margin-bottom: 1.5rem;
  color: #ffa500;
}

.testimonial-text {
  font-size: 1.1rem;
  line-height: 1.8;
  color: #333333;
  margin-bottom: 2rem;
  font-style: italic;
}

.testimonial-author {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding-top: 1.5rem;
  border-top: 2px solid #f0f0f0;
}

.testimonial-author .author-avatar {
  width: 60px;
  height: 60px;
  background: linear-gradient(135deg, #e63946, #c1121f);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 1.3rem;
}

.author-details h4 {
  font-size: 1.1rem;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 0.25rem;
}

.author-details p {
  font-size: 0.95rem;
  color: #666666;
}

/* FAQ SECTION */
.faq-section {
  padding: 8rem 0;
  background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
}

.faq-list {
  max-width: 900px;
  margin: 4rem auto 0;
}

.faq-item {
  background: white;
  padding: 2rem;
  border-radius: 15px;
  margin-bottom: 1.5rem;
  box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  border-left: 4px solid transparent;
}

.faq-item:hover {
  transform: translateX(10px);
  border-left-color: #e63946;
  box-shadow: 0 10px 30px rgba(230, 57, 70, 0.15);
}

.faq-item h3 {
  font-size: 1.3rem;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 1rem;
}

.faq-item p {
  font-size: 1.05rem;
  color: #666666;
  line-height: 1.8;
}

/* FINAL CTA SECTION */
.final-cta-section {
  padding: 8rem 0;
  background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
  position: relative;
  overflow: hidden;
}

.final-cta-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 50%, rgba(230, 57, 70, 0.2) 0%, transparent 50%),
              radial-gradient(circle at 80% 50%, rgba(193, 18, 31, 0.2) 0%, transparent 50%);
  pointer-events: none;
}

.cta-box {
  text-align: center;
  position: relative;
  z-index: 2;
}

.cta-box h2 {
  font-size: 4.2rem;
  font-weight: 900;
  color: white;
  margin-bottom: 1rem;
  animation: fadeInUp 0.8s ease-out;
}

.cta-box > p {
  font-size: 1.3rem;
  color: #cccccc;
  margin-bottom: 3rem;
}

.final-cta-section .cta-buttons {
  display: flex;
  justify-content: center;
  gap: 2rem;
  margin-bottom: 2rem;
}

.final-cta-section .cta-btn {
  padding: 1.25rem 3rem;
  font-size: 1.15rem;
}

.cta-urgency {
  font-size: 1.2rem;
  color: #ffa500;
  font-weight: 700;
  animation: pulse 2s ease-in-out infinite;
}

/* RESPONSIVE UPDATES */
@media (max-width: 992px) {
  .about-layout,
  .programs-grid,
  .testimonials-grid,
  .why-grid {
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .about-stats {
    grid-template-columns: repeat(2, 1fr);
  }

  .partners-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .program-card.featured {
    transform: scale(1);
  }
}

@media (max-width: 768px) {
  .about-stats {
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .stat-number {
    font-size: 2rem;
  }

  .cta-box h2 {
    font-size: 2rem;
  }

  .final-cta-section .cta-buttons {
    flex-direction: column;
    gap: 1rem;
  }

  .partners-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* ===============================================
   NEW DETAILED SECTIONS STYLES
   =============================================== */

/* Key Features Detailed Section */
.key-features-section {
  padding: 6rem 0;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
}

.detailed-features-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 3rem;
  margin-top: 4rem;
}

.detailed-feature-card {
  background: white;
  padding: 3rem;
  border-radius: 20px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
  position: relative;
  transition: all 0.3s ease;
  border: 2px solid transparent;
}

.detailed-feature-card:hover {
  transform: translateY(-10px);
  box-shadow: 0 20px 50px rgba(230, 57, 70, 0.15);
  border-color: #e63946;
}

.feature-number {
  position: absolute;
  top: -20px;
  right: 30px;
  font-size: 5rem;
  font-weight: 900;
  color: rgba(230, 57, 70, 0.1);
  line-height: 1;
}

.feature-icon-large {
  font-size: 4rem;
  margin-bottom: 1.5rem;
  display: inline-block;
}

.detailed-feature-card h3 {
  font-size: 1.8rem;
  font-weight: 800;
  color: #1a1a1a;
  margin-bottom: 1rem;
}

.detailed-feature-card > p {
  font-size: 1.05rem;
  line-height: 1.8;
  color: #555;
  margin-bottom: 1.5rem;
}

.feature-details {
  list-style: none;
  padding: 0;
  margin: 0;
}

.feature-details li {
  padding: 0.75rem 0;
  padding-left: 1.5rem;
  color: #666;
  font-size: 0.95rem;
  position: relative;
  border-top: 1px solid #eee;
}

.feature-details li:first-child {
  border-top: none;
}

.feature-details li::before {
  content: '▶';
  position: absolute;
  left: 0;
  color: #e63946;
  font-size: 0.7rem;
}

/* Learning Journey Section - Interactive Grid Layout */
.learning-journey-section {
  padding: 6rem 0;
  background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
  position: relative;
  overflow: hidden;
}

.learning-journey-section::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 800px;
  height: 800px;
  background: radial-gradient(circle, rgba(230, 57, 70, 0.05) 0%, transparent 70%);
  border-radius: 50%;
  animation: float-background 20s ease-in-out infinite;
}

@keyframes float-background {
  0%, 100% { transform: translate(0, 0) scale(1); }
  50% { transform: translate(-50px, 50px) scale(1.1); }
}

.journey-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 3rem;
  margin-top: 4rem;
  position: relative;
  z-index: 2;
}

.journey-card {
  position: relative;
  perspective: 1000px;
  animation: fadeInUp 0.6s ease-out backwards;
}

.journey-card:nth-child(1) { animation-delay: 0.1s; }
.journey-card:nth-child(2) { animation-delay: 0.2s; }
.journey-card:nth-child(3) { animation-delay: 0.3s; }
.journey-card:nth-child(4) { animation-delay: 0.4s; }
.journey-card:nth-child(5) { animation-delay: 0.5s; }
.journey-card:nth-child(6) { animation-delay: 0.6s; }

.journey-card-inner {
  background: white;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  position: relative;
  height: 100%;
  display: flex;
  flex-direction: column;
}

.journey-card:hover .journey-card-inner {
  transform: translateY(-15px) scale(1.02);
  box-shadow: 0 25px 60px rgba(230, 57, 70, 0.25);
}

.journey-image-wrapper {
  position: relative;
  width: 100%;
  height: 240px;
  overflow: hidden;
}

.journey-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
  filter: brightness(0.9);
}

.journey-card:hover .journey-image {
  transform: scale(1.15);
  filter: brightness(1);
}

.journey-icon {
  position: absolute;
  bottom: -30px;
  right: 20px;
  width: 60px;
  height: 60px;
  background: linear-gradient(135deg, #e63946, #c1121f);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.8rem;
  box-shadow: 0 8px 20px rgba(230, 57, 70, 0.4);
  z-index: 10;
  transition: all 0.3s ease;
  animation: bounce-icon 2s ease-in-out infinite;
}

@keyframes bounce-icon {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}

.journey-card:hover .journey-icon {
  transform: rotate(360deg) scale(1.1);
  animation: none;
}

.journey-content {
  padding: 2.5rem;
  padding-top: 3rem;
  flex-grow: 1;
  display: flex;
  flex-direction: column;
}

.journey-title {
  font-size: 1.4rem;
  font-weight: 800;
  color: #1a1a1a;
  margin-bottom: 1rem;
  line-height: 1.3;
  position: relative;
  padding-left: 15px;
}

.journey-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4px;
  background: linear-gradient(180deg, #e63946, #c1121f);
  border-radius: 2px;
  transition: width 0.3s ease;
}

.journey-card:hover .journey-title::before {
  width: 8px;
}

.journey-description {
  font-size: 1rem;
  line-height: 1.8;
  color: #555;
  margin-bottom: 1.5rem;
  flex-grow: 1;
}

.journey-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-top: auto;
}

.journey-tag {
  background: rgba(230, 57, 70, 0.08);
  color: #e63946;
  padding: 0.5rem 1rem;
  border-radius: 20px;
  font-size: 0.85rem;
  font-weight: 600;
  border: 1px solid rgba(230, 57, 70, 0.2);
  transition: all 0.3s ease;
  cursor: default;
}

.journey-card:hover .journey-tag {
  background: linear-gradient(135deg, #e63946, #c1121f);
  color: white;
  border-color: transparent;
  transform: translateY(-2px);
}

/* Phase-specific color accents */
.journey-card[data-phase="foundation"]:hover .journey-card-inner {
  border-top: 4px solid #e63946;
}

.journey-card[data-phase="core"]:hover .journey-card-inner {
  border-top: 4px solid #c1121f;
}

.journey-card[data-phase="advanced"]:hover .journey-card-inner {
  border-top: 4px solid #ff6b6b;
}

.journey-card[data-phase="capstone"]:hover .journey-card-inner {
  border-top: 4px solid #ee5a6f;
}

.journey-card[data-phase="interview"]:hover .journey-card-inner {
  border-top: 4px solid #d62828;
}

.journey-card[data-phase="career"]:hover .journey-card-inner {
  border-top: 4px solid #9d0208;
}

.journey-card {
  cursor: pointer;
}

.journey-more-btn {
  margin-top: 1.5rem;
  padding: 0.6rem 1.5rem;
  background: #e63946;
  color: white;
  border: none;
  border-radius: 8px;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  white-space: nowrap;
  box-shadow: 0 2px 8px rgba(230, 57, 70, 0.3);
}

.journey-more-btn:hover {
  background: #c1121f;
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(230, 57, 70, 0.4);
}

.journey-card:hover .journey-more-btn {
  background: #d32f2f;
}

/* Modal Styles */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.9);
  backdrop-filter: blur(10px);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  overflow-y: auto;
  animation: fadeIn 0.4s ease;
  scrollbar-width: none; /* Firefox */
  -ms-overflow-style: none; /* IE and Edge */
}

.modal-overlay::-webkit-scrollbar {
  display: none; /* Chrome, Safari, Opera */
}

@keyframes fadeIn {
  from {
    opacity: 0;
    backdrop-filter: blur(0);
  }
  to {
    opacity: 1;
    backdrop-filter: blur(10px);
  }
}

.modal-container {
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
  border-radius: 0;
  max-width: 100%;
  width: 100%;
  height: 100vh;
  overflow-y: auto;
  position: relative;
  box-shadow: none;
  animation: slideInModal 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.modal-container::-webkit-scrollbar {
  display: none;
}

@keyframes slideInModal {
  from {
    transform: scale(0.8);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.modal-close {
  position: fixed;
  top: 2rem;
  right: 2rem;
  width: 50px;
  height: 50px;
  border-radius: 50%;
  background: white;
  border: none;
  font-size: 1.5rem;
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #e63946;
  z-index: 10000;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
}

.modal-close:hover {
  background: #e63946;
  color: white;
  transform: rotate(90deg) scale(1.1);
  box-shadow: 0 6px 30px rgba(230, 57, 70, 0.4);
}

.modal-content {
  padding: 5rem 4rem 4rem;
  max-width: 1200px;
  margin: 0 auto;
}

.modal-header {
  text-align: center;
  margin-bottom: 4rem;
  padding-bottom: 3rem;
  border-bottom: 3px solid #e63946;
  position: relative;
  animation: fadeInDown 0.6s ease 0.2s both;
}

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.modal-header::after {
  content: '';
  position: absolute;
  bottom: -3px;
  left: 50%;
  transform: translateX(-50%);
  width: 100px;
  height: 3px;
  background: white;
}

.modal-icon {
  font-size: 5rem;
  margin-bottom: 1.5rem;
  display: inline-block;
  animation: bounceIn 0.8s ease 0.3s both;
  filter: drop-shadow(0 4px 10px rgba(230, 57, 70, 0.3));
}

@keyframes bounceIn {
  0% {
    transform: scale(0);
  }
  50% {
    transform: scale(1.2);
  }
  100% {
    transform: scale(1);
  }
}

.modal-title {
  font-size: 3rem;
  font-weight: 900;
  background: linear-gradient(135deg, #e63946, #c1121f);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 1.5rem;
  line-height: 1.2;
  animation: fadeInUp 0.6s ease 0.4s both;
}

.modal-subtitle {
  font-size: 1.2rem;
  color: #555;
  line-height: 1.8;
  max-width: 800px;
  margin: 0 auto;
  animation: fadeInUp 0.6s ease 0.5s both;
}

.modal-body {
  display: flex;
  flex-direction: column;
  gap: 4rem;
}

.modal-section-title {
  font-size: 1.8rem;
  font-weight: 800;
  color: #1a1a1a;
  margin-bottom: 2rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  position: relative;
  padding-left: 20px;
}

.modal-section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 5px;
  background: linear-gradient(180deg, #e63946, #c1121f);
  border-radius: 3px;
}

/* Video Section */
.modal-video-section {
  background: white;
  padding: 3rem;
  border-radius: 20px;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
  animation: fadeInUp 0.6s ease 0.6s both;
}

.modal-video-wrapper {
  position: relative;
  width: 100%;
  padding-bottom: 56.25%;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 15px 50px rgba(0, 0, 0, 0.3);
  transition: transform 0.3s ease;
}

.modal-video-wrapper:hover {
  transform: scale(1.02);
}

.modal-video {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

/* Highlights Section */
.modal-highlights-section {
  animation: fadeInUp 0.6s ease 0.7s both;
}

.modal-highlights-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: grid;
  gap: 1rem;
}

.modal-highlight-item {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1.25rem 1.5rem;
  background: #f8f9fa;
  border-radius: 8px;
  border-left: 4px solid #e63946;
  transition: all 0.3s ease;
  font-size: 1rem;
  line-height: 1.6;
  color: #333;
  box-shadow: none;
  opacity: 0;
  animation: slideInLeft 0.6s ease forwards;
}

.modal-highlight-item:nth-child(1) { animation-delay: 0.8s; }
.modal-highlight-item:nth-child(2) { animation-delay: 1s; }
.modal-highlight-item:nth-child(3) { animation-delay: 1.2s; }
.modal-highlight-item:nth-child(4) { animation-delay: 1.4s; }
.modal-highlight-item:nth-child(5) { animation-delay: 1.6s; }
.modal-highlight-item:nth-child(6) { animation-delay: 1.8s; }

@keyframes slideInLeft {
  0% {
    opacity: 0;
    transform: translateX(-50px);
  }
  100% {
    opacity: 1;
    transform: translateX(0);
  }
}

.modal-highlight-item:hover {
  background: white;
  border-left-width: 5px;
  box-shadow: 0 3px 10px rgba(0, 0, 0, 0.08);
  transform: translateX(5px);
}

.highlight-check {
  width: 28px;
  height: 28px;
  min-width: 28px;
  background: #e63946;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  font-size: 0.85rem;
  flex-shrink: 0;
}

/* Tools Section */
.modal-tools-section {
  animation: fadeInUp 0.6s ease 2s both;
}

.modal-tools-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
}

.modal-tool-badge {
  padding: 0.75rem 1.5rem;
  background: linear-gradient(135deg, #e63946, #c1121f);
  color: white;
  border-radius: 25px;
  font-weight: 600;
  font-size: 0.95rem;
  box-shadow: 0 4px 15px rgba(230, 57, 70, 0.3);
  transition: all 0.3s ease;
  opacity: 0;
  animation: fadeInScale 0.5s ease forwards;
}

.modal-tool-badge:nth-child(1) { animation-delay: 2.1s; }
.modal-tool-badge:nth-child(2) { animation-delay: 2.2s; }
.modal-tool-badge:nth-child(3) { animation-delay: 2.3s; }
.modal-tool-badge:nth-child(4) { animation-delay: 2.4s; }
.modal-tool-badge:nth-child(5) { animation-delay: 2.5s; }
.modal-tool-badge:nth-child(6) { animation-delay: 2.6s; }
.modal-tool-badge:nth-child(7) { animation-delay: 2.7s; }
.modal-tool-badge:nth-child(8) { animation-delay: 2.8s; }

@keyframes fadeInScale {
  0% {
    opacity: 0;
    transform: scale(0.5);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

.modal-tool-badge:hover {
/* Images Section */
.modal-images-section {
  animation: fadeInUp 0.6s ease 2.9s both;
}

.modal-images-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
}

.modal-image {
  width: 100%;
  height: 280px;
  object-fit: cover;
  border-radius: 12px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  transition: all 0.4s ease;
  opacity: 0;
  animation: fadeInUp 0.6s ease forwards;
}

.modal-image:nth-child(1) { animation-delay: 3s; }
.modal-image:nth-child(2) { animation-delay: 3.2s; }

@keyframes fadeInUp {
  0% {
    opacity: 0;
    transform: translateY(30px);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

.modal-image:hover {
  transform: translateY(-5px);
  box-shadow: 0 12px 35px rgba(0, 0, 0, 0.2);
}
.modal-image:hover {
  transform: scale(1.05) rotate(2deg);
  box-shadow: 0 15px 50px rgba(230, 57, 70, 0.3);
}
/* Outcomes Section */
.modal-outcomes-section {
  background: linear-gradient(135deg, #e63946 0%, #c1121f 100%);
  padding: 2.5rem;
  border-radius: 16px;
  color: white;
  box-shadow: 0 10px 40px rgba(230, 57, 70, 0.3);
  opacity: 0;
  animation: fadeInUp 0.6s ease 3.4s forwards;
  position: relative;
  overflow: hidden;
}

.modal-outcomes-section::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.08) 0%, transparent 70%);
  animation: rotate 20s linear infinite;
}

@keyframes rotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.modal-outcomes-section .modal-section-title {
  color: white;
  position: relative;
  z-index: 1;
}

.modal-outcomes-section .modal-section-title::before {
  background: white;
}

.modal-outcomes-text {
  font-size: 1.1rem;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.95);
  position: relative;
  z-index: 1;
} z-index: 1;
/* CTA Section */
.modal-cta {
  display: flex;
  gap: 1.5rem;
  justify-content: center;
  padding-top: 3rem;
  opacity: 0;
  animation: fadeInUp 0.6s ease 3.6s forwards;
}

.modal-enroll-btn,
.modal-contact-btn {
  padding: 1rem 2.5rem;
  border-radius: 12px;
  font-size: 1rem;
  font-weight: 700;
  border: none;
  cursor: pointer;
  transition: all 0.3s ease;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.modal-enroll-btn {
  background: linear-gradient(135deg, #e63946, #c1121f);
  color: white;
  box-shadow: 0 8px 25px rgba(230, 57, 70, 0.3);
  opacity: 0;
  animation: fadeInScale 0.5s ease 3.7s forwards;
}

.modal-enroll-btn:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 35px rgba(230, 57, 70, 0.4);
}

.modal-contact-btn {
  background: white;
  color: #e63946;
  border: 2px solid #e63946;
  opacity: 0;
  animation: fadeInScale 0.5s ease 3.9s forwards;
}

.modal-contact-btn:hover {
  background: #e63946;
  color: white;
  transform: translateY(-3px);
  box-shadow: 0 8px 25px rgba(230, 57, 70, 0.3);
} transform: translateY(-5px);
  box-shadow: 0 10px 30px rgba(230, 57, 70, 0.3);
}

/* Responsive Modal */
@media (max-width: 768px) {
  .modal-content {
    padding: 4rem 1.5rem 3rem;
  }

  .modal-close {
    top: 1rem;
    right: 1rem;
    width: 40px;
    height: 40px;
  }

  .modal-title {
    font-size: 2rem;
  }

  .modal-subtitle {
    font-size: 1rem;
  }

  .modal-section-title {
    font-size: 1.4rem;
  }

  .modal-images-grid {
    grid-template-columns: 1fr;
  }

  .modal-cta {
    flex-direction: column;
    gap: 1rem;
  }

  .modal-enroll-btn,
  .modal-contact-btn {
    width: 100%;
  }

  .modal-video-section {
    padding: 1.5rem;
  }
}


/* RESPONSIVE FOR NEW SECTIONS */
@media (max-width: 992px) {
  .detailed-features-grid {
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .why-grid {
    grid-template-columns: 1fr;
  }

  .metrics-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .journey-grid {
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
}

@media (max-width: 768px) {
  .detailed-feature-card {
    padding: 2rem;
  }

  .feature-number {
    font-size: 3rem;
    top: -15px;
    right: 20px;
  }

  .feature-icon-large {
    font-size: 3rem;
  }

  .detailed-feature-card h3 {
    font-size: 1.4rem;
  }

  .metrics-grid {
    grid-template-columns: 1fr;
  }

  .metric-number {
    font-size: 2.5rem;
  }

  .journey-grid {
    grid-template-columns: 1fr;
  }

  .journey-image-wrapper {
    height: 200px;
  }

  .journey-content {
    padding: 1.5rem;
    padding-top: 2.5rem;
  }

  .journey-title {
    font-size: 1.2rem;
  }

  .journey-description {
    font-size: 0.95rem;
  }

  .journey-icon {
    width: 50px;
    height: 50px;
    font-size: 1.5rem;
    bottom: -25px;
  }

  .journey-tags {
    gap: 0.5rem;
  }

  .journey-tag {
    font-size: 0.75rem;
    padding: 0.4rem 0.8rem;
  }
}

